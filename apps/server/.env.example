# 1. Supabase 대시보드에서 Connect → URI 복사
# 2. 아래 YOUR_PASSWORD를 실제 DB 비밀번호로 바꾸세요
# 3. 이 파일을 .env로 복사: cp .env.example .env

# Session 모드(5432) 권장. Supabase Connect 버튼에서 복사 후 비밀번호만 교체
DATABASE_URL=postgresql://postgres.프로젝트ID:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
PORT=5005

# Render 연동 (선택): scripts/set-render-env.mjs 실행 시 사용
# RENDER_API_KEY=your_key_from https://dashboard.render.com/settings/api-keys
